// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "diagnostics": {
    "inline": {
      "enabled": false
    }
  },
  "diff_view_style": "unified",
  "git_panel": {
    "tree_view": false
  },
  "edit_predictions": {
    "mode": "subtle",
    "provider": "zed"
  },
  "context_servers": {
    "mcp-server-github": {
      "enabled": true,
      "remote": false,
      "settings": {}
    }
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    },
    "github-copilot-cli": {
      "type": "registry"
    },
    "opencode": {
      "type": "registry"
    }
  },
  "icon_theme": "Warm Charmed Icons",
  "theme": "Aura Dark",
  "theme_overrides": {
    "Aura Dark": {
      "editor.document_highlight.read_background": "#00000000",
      "editor.document_highlight.write_background": "#00000000",
      "border.variant": "#15141C",
      "border": "#15141C",
      "title_bar.background": "#15141C",
      "panel.background": "#15141C",
      "panel.focused_border": "#4E466E",
      "players": [
        {
          "cursor": "#BD9DFF"
        }
      ],
      "syntax": {
        "comment": {
          "font_style": "italic"
        },
        "comment.doc": {
          "font_style": "italic"
        }
      }
    }
  },
  "title_bar": {
    "show_branch_icon": false,
    "show_onboarding_banner": false
  },
  "tab_bar": {
    "show": true
  },
  "toolbar": {
    "quick_actions": false
  },
  "project_panel": {
    "dock": "left",
    "default_width": 400,
    "hide_root": true,
    "auto_fold_dirs": false,
    "starts_open": false,
    "git_status": false,
    "sticky_scroll": false,
    "scrollbar": {
      "show": "never"
    },
    "indent_guides": {
      "show": "never"
    }
  },
  "outline_panel": {
    "default_width": 300,
    "indent_guides": {
      "show": "never"
    }
  },
  "file_finder": {
    "modal_max_width": "large"
  },
  "scrollbar": {
    "show": "never"
  },
  "gutter": {
    "min_line_number_digits": 0,
    "folds": false,
    "runnables": false
  },
  "indent_guides": {
    "enabled": false
  },
  "ui_font_family": "Dank Mono",
  "ui_font_size": 20,
  "buffer_font_family": "Dank Mono",
  "buffer_font_size": 20,
  "buffer_font_features": {
    "calt": false // Disable ligatures
  },
  "buffer_line_height": {
    "custom": 1.8
  },
  "agent_buffer_font_size": 20,
  "terminal": {
    "font_family": "Dank Mono"
  },
  "vim_mode": true,
  "vim": {
    "toggle_relative_line_numbers": true
  },
  "multi_cursor_modifier": "cmd_or_ctrl",
  "cursor_shape": "block",
  "cursor_blink": false,
  "selection_highlight": false,
  "drag_and_drop_selection": {
    "enabled": false
  },
  "seed_search_query_from_cursor": "never",
  "current_line_highlight": "all",
  "show_whitespaces": "selection",
  "tab_size": 2,
  "show_completions_on_input": true,
  "show_completion_documentation": false,
  "hover_popover_enabled": false,
  "format_on_save": "on",
  "autosave": "on_focus_change",
  "extend_comment_on_newline": false,
  "horizontal_scroll_margin": 1,
  "vertical_scroll_margin": 1,
  "when_closing_with_no_tabs": "keep_window_open",
  "close_on_file_delete": true,
  "restore_on_file_reopen": true,
  "restore_on_startup": "last_session",
  "session": {
    "restore_unsaved_buffers": true
  },
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true
    }
  },
  "centered_layout": {
    "right_padding": 0.15,
    "left_padding": 0.15
  },
  "agent": {
    "profiles": {
      "front-end": {
        "default_model": {
          "provider": "copilot_chat",
          "model": "claude-opus-4.6"
        },
        "name": "Front-end",
        "tools": {
          "thinking": true,
          "terminal": true,
          "save_file": true,
          "restore_file_from_disk": true,
          "read_file": true,
          "open": true,
          "now": true,
          "move_path": true,
          "list_directory": true,
          "find_path": true,
          "grep": true,
          "fetch": true,
          "diagnostics": true,
          "edit_file": true,
          "delete_path": true,
          "create_directory": true,
          "copy_path": true
        },
        "enable_all_context_servers": false,
        "context_servers": {}
      },
      "plan": {
        "default_model": {
          "provider": "copilot_chat",
          "model": "gpt-5.3-codex"
        },
        "name": "Plan",
        "tools": {
          "open": true,
          "terminal": true,
          "read_file": true,
          "list_directory": true,
          "grep": true,
          "find_path": true,
          "fetch": true,
          "diagnostics": true,
          "thinking": true
        },
        "enable_all_context_servers": false,
        "context_servers": {}
      }
    },
    "default_profile": "write",
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.6"
    },
    "favorite_models": [
      {
        "provider": "copilot_chat",
        "model": "gpt-5.3-codex",
        "enable_thinking": false
      },
      {
        "provider": "copilot_chat",
        "model": "claude-sonnet-4.6",
        "enable_thinking": false
      },
      {
        "provider": "copilot_chat",
        "model": "claude-opus-4.6",
        "enable_thinking": false
      },
      {
        "provider": "copilot_chat",
        "model": "gemini-3.1-pro-preview",
        "enable_thinking": false
      }
    ],
    "model_parameters": []
  },
  "which_key": {
    "enabled": true,
    "delay_ms": 100
  }
}
