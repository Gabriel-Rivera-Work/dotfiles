{
  // ========== Appearance & Theme ==========
  "workbench.colorTheme": "Aura Dark",
  "workbench.iconTheme": "helium-icon-theme",
  "helium-icon-theme.hidesExplorerArrows": true,
  "workbench.reduceMotion": "on",
  "window.autoDetectColorScheme": true,
  "window.zoomLevel": 1.8,
  "window.commandCenter": false,
  "workbench.startupEditor": "none",
  "workbench.tips.enabled": false,
  "workbench.editor.showTabs": "multiple",
  "workbench.tree.enableStickyScroll": false,
  "workbench.list.smoothScrolling": false,
  "workbench.tree.renderIndentGuides": "none",
  "workbench.layoutControl.enabled": false,
  "workbench.browser.showInTitleBar": false,
  "breadcrumbs.enabled": true,

  "workbench.colorCustomizations": {
    "editor.lineHighlightBackground": "#ffffff08",
    "editorCursor.background": "#000000",
    "editorOverviewRuler.wordHighlightStrongForeground": "#0000",
    "editorOverviewRuler.selectionHighlightForeground": "#0000",
    "editorOverviewRuler.rangeHighlightForeground": "#0000",
    "editorOverviewRuler.wordHighlightForeground": "#0000",
    "editorOverviewRuler.bracketMatchForeground": "#0000",
    "editorOverviewRuler.findMatchForeground": "#0000",
    "editorOverviewRuler.modifiedForeground": "#0000",
    "editorOverviewRuler.deletedForeground": "#0000",
    "editorOverviewRuler.warningForeground": "#0000",
    "editorOverviewRuler.addedForeground": "#0000",
    "editorOverviewRuler.errorForeground": "#0000",
    "editorOverviewRuler.infoForeground": "#0000",
    "editorOverviewRuler.border": "#0000",
    "sideBar.border": "#0000",
    "tab.activeBackground": "#0000",
    "tab.border": "#0000",
    "focusBorder": "#0000",
    "menu.border": "#0000",
    "titleBar.border": "#0000",
    "activityBar.border": "#0000",
    "scrollbarSlider.background": "#0000",
    "scrollbarSlider.hoverBackground": "#0000",
    "scrollbarSlider.activeBackground": "#0000"
  },

  // ========== Editor Basics ==========
  "editor.fontFamily": "Dank Mono",
  "editor.fontWeight": "normal",
  "editor.fontSize": 16.5,
  "editor.fontLigatures": false,
  "editor.cursorStyle": "block",
  "editor.lineHeight": 1.9,
  "editor.cursorBlinking": "solid",
  "editor.cursorSmoothCaretAnimation": "off",
  "editor.cursorSurroundingLines": 8,
  "editor.smoothScrolling": false,
  "editor.lineNumbers": "relative",
  "editor.wordWrap": "on",
  "editor.minimap.enabled": false,
  "editor.stickyScroll.enabled": false,
  "editor.linkedEditing": true,
  "editor.formatOnSave": true,
  "editor.trimAutoWhitespace": true,
  "editor.renderWhitespace": "none",
  "editor.renderLineHighlight": "all",
  "editor.matchBrackets": "never",
  "editor.guides.indentation": false,
  "editor.guides.highlightActiveIndentation": false,
  "editor.guides.bracketPairs": false,
  "editor.bracketPairColorization.enabled": false,
  "editor.suggest.snippetsPreventQuickSuggestions": false,
  "editor.suggestSelection": "first",
  "editor.scrollbar.horizontal": "hidden",
  "editor.scrollbar.vertical": "hidden",
  "editor.folding": false,
  "editor.codeLens": false,
  "editor.hover.enabled": "off",
  "editor.parameterHints.enabled": false,
  "editor.lightbulb.enabled": "off",
  "editor.occurrencesHighlight": "off",
  "editor.selectionHighlight": false,
  "editor.dragAndDrop": false,
  "editor.find.seedSearchStringFromSelection": "never",
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.hg/store/**": true,
    "**/node_modules/**": true,
    "**/dist/**": true
  },
  "search.maxResults": 1000,

  // ========== Language-specific Formatters ==========
  "[typescript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[jsonc]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[css]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },

  // ========== Files ==========
  "files.autoSave": "onFocusChange",
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.compactFolders": false,
  "explorer.decorations.badges": false,
  "explorer.decorations.colors": false,

  // ========== Terminal ==========
  "terminal.integrated.fontFamily": "Dank Mono",
  "terminal.integrated.fontSize": 16.5,
  "terminal.integrated.lineHeight": 1.2,
  "terminal.integrated.fontWeight": "normal",
  "terminal.integrated.stickyScroll.enabled": false,
  "terminal.integrated.suggest.enabled": false,
  "terminal.integrated.cursorBlinking": false,
  "terminal.integrated.smoothScrolling": false,
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.shellIntegration.decorationsEnabled": "never",

  "terminal.external.osxExec": "cmux.app",

  // ========== Git ==========
  "git.enableSmartCommit": true,
  "git.confirmSync": false,
  "git.decorations.enabled": false,

  "git.blame.editorDecoration.enabled": true,
  "git.blame.editorDecoration.template": "${authorName}, ${authorDateAgo}",
  "git.blame.editorDecoration.disableHover": true,
  "git.blame.statusBarItem.enabled": false,

  // ========== Diff ==========
  "diffEditor.ignoreTrimWhitespace": false,

  // ========== Accessibility ==========
  "editor.accessibilitySupport": "off",

  // ========== Inlay Hints ==========
  "editor.inlayHints.enabled": "off",
  "js/ts.inlayHints.parameterNames.enabled": "none",
  "js/ts.inlayHints.variableTypes.enabled": false,
  "js/ts.inlayHints.propertyDeclarationTypes.enabled": false,
  "js/ts.inlayHints.parameterTypes.enabled": false,
  "js/ts.inlayHints.functionLikeReturnTypes.enabled": false,
  "python.analysis.inlayHints.callArgumentNames": "off",
  "python.analysis.inlayHints.variableTypes": false,
  "python.analysis.inlayHints.functionReturnTypes": false,
  "python.analysis.inlayHints.pytestParameters": false,
  "python.analysis.typeCheckingMode": "standard",
  "csharp.inlayHints.enableInlayHintsForImplicitObjectCreation": false,
  "csharp.inlayHints.enableInlayHintsForImplicitVariableTypes": false,
  "csharp.inlayHints.enableInlayHintsForLambdaParameterTypes": false,
  "csharp.inlayHints.enableInlayHintsForTypes": false,
  "dotnet.inlayHints.enableInlayHintsForIndexerParameters": false,
  "dotnet.inlayHints.enableInlayHintsForLiteralParameters": false,
  "dotnet.inlayHints.enableInlayHintsForObjectCreationParameters": false,
  "dotnet.inlayHints.enableInlayHintsForOtherParameters": false,
  "dotnet.inlayHints.enableInlayHintsForParameters": false,
  "dotnet.inlayHints.suppressInlayHintsForParametersThatDifferOnlyBySuffix": true,
  "dotnet.inlayHints.suppressInlayHintsForParametersThatMatchArgumentName": true,
  "dotnet.inlayHints.suppressInlayHintsForParametersThatMatchMethodIntent": true,

  // ========== Neovim (VSCode Neovim) ==========
  "keyboard.dispatch": "keyCode",
  "vscode-neovim.useWSL": false,
  "vscode-neovim.neovimExecutablePaths.darwin": "/opt/homebrew/bin/nvim",
  "vscode-neovim.InitVimPaths.darwin": "~/dotfiles/nvim/init.lua",
  "vscode-neovim.highlightGroups.highlights": {
    "Directory": { "link": "Directory" },
    "IncSearch": { "link": "IncSearch" },
    "Search": { "link": "Search" },
    "LineNr": { "link": "LineNr" },
    "CursorLine": { "link": "CursorLine" },
    "CursorLineNr": { "link": "CursorLineNr" },
    "SignColumn": { "link": "SignColumn" },
    "StatusLine": { "link": "StatusLine" },
    "NormalFloat": { "link": "NormalFloat" },
    "Visual": { "link": "Visual" }
  },
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1
  },

  // ========== Token Colors ==========
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": "comment",
        "settings": {
          "fontStyle": "italic"
        }
      },
      {
        "name": "envKeys",
        "scope": "string.quoted.single.ini,constant.numeric.ini,string.quoted.double.ini",
        "settings": {
          "foreground": "#19354900"
        }
      },
      {
        "scope": "keyword.other.dotenv",
        "settings": {
          "foreground": "#FF000000"
        }
      }
    ]
  },

  // ========== GitHub Copilot & Chat ==========
  "github.copilot.enable": {
    "*": true,
    "plaintext": true,
    "markdown": true,
    "scminput": false,
    "yaml": true
  },
  "github.copilot.chat.codeGeneration.instructions": [
    { "text": "Write clean, simple, readable code." },
    { "text": "Implement features in the simplest possible way." },
    { "text": "Keep files small and focused (<200 lines)." },
    { "text": "Test after every meaningful change." },
    { "text": "Focus on core functionality before optimization." },
    { "text": "Use clear, consistent naming." },
    {
      "text": "Think thoroughly before coding; write 2-3 reasoning paragraphs."
    },
    { "text": "ALWAYS write simple, clean and modular code." },
    {
      "text": "Use clear and easy-to-understand language; write in short sentences."
    },
    {
      "text": "ALWAYS use the latest and most up-to-date information available; use the web search functionality to find the latest information. REMEMBER ALWAYS to use the latest information available."
    },
    {
      "text": "DO NOT JUMP TO CONCLUSIONS; consider multiple possible causes before deciding."
    },
    { "text": "Explain the problem in plain English." },
    {
      "text": "Make minimal necessary changes, changing as few lines of code as possible."
    },
    {
      "text": "In case of strange errors, ask the user to perform a Perplexity web search to find the latest information."
    },
    {
      "text": "Verify each new feature works by telling the user how to test it."
    },
    {
      "text": "DO NOT write complicated and confusing code; opt for the simple & modular approach."
    },
    {
      "text": "When not sure what to do, tell the user to perform a web search."
    },
    {
      "text": "Always try to add more helpful and explanatory comments into our code."
    },
    {
      "text": "NEVER delete old comments unless they are obviously wrong or obsolete."
    },
    {
      "text": "Include LOTS of explanatory comments in your code; ALWAYS write well-documented code."
    },
    {
      "text": "Document all changes and their reasoning in the comments you write."
    },
    {
      "text": "When writing comments, use clear and easy-to-understand language; write in short sentences."
    },
    { "file": ".github/copilot-instructions.md" }
  ],
  "github.copilot.chat.codesearch.enabled": true,
  "github.copilot.nextEditSuggestions.enabled": true,
  "github.copilot.chat.codeGeneration.useInstructionFiles": true,

  // ========== Chat / Instructions Files ==========
  "chat.instructionsFilesLocations": {
    ".github/instructions": true
  },

  // ========== Project / Misc ==========
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "window.density.editorTabHeight": "default",
  "zenMode.centerLayout": false,
  "zenMode.hideLineNumbers": false,
  "zenMode.hideStatusBar": false,

  // ========== Cycler Extension ==========
  "settings.cycle": [
    {
      "id": "lineNumbers",
      "values": [
        { "editor.lineNumbers": "on" },
        { "editor.lineNumbers": "off" }
      ]
    },
    {
      "id": "relativeLineNumbers",
      "values": [
        { "editor.lineNumbers": "relative" },
        { "editor.lineNumbers": "on" }
      ]
    },
    {
      "id": "guideIndentation",
      "values": [
        { "editor.guides.indentation": true },
        { "editor.guides.indentation": false }
      ]
    }
  ],

  // ========== Misc / Remaining ==========
  "chat.mcp.gallery.enabled": true,
  "workbench.editor.empty.hint": "hidden",
  "window.titleBarStyle": "custom",
  "workbench.editorAssociations": {
    "*.copilotmd": "vscode.markdown.preview.editor",
    "*.opus": "default"
  },
  "telemetry.editStats.enabled": false,
  "telemetry.feedback.enabled": false,
  "dotnetAcquisitionExtension.enableTelemetry": false,
  "files.associations": {
    ".env*": "dotenv"
  },
  "dotenv.enableAutocloaking": true,
  "workbench.preferredDarkColorTheme": "Aura Dark",
  "github.copilot.chat.copilotMemory.enabled": true,
  "workbench.browser.openLocalhostLinks": true,
  "github.copilot.selectedCompletionModel": "",
  "editor.tabCompletion": "on",
  "chat.viewSessions.orientation": "stacked",
  "workbench.activityBar.location": "top",
  "scm.diffDecorations": "gutter",
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.js",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.tsx": "${capture}.ts",
    "tsconfig.json": "tsconfig.*.json",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
    "*.cs": "${capture}.designer.cs,${capture}.g.cs,${capture}.generated.cs,${capture}.run.json,${capture}.settings.json,${capture}.settings.*.json",
    "*.csproj": "${capture}.csproj.user",
    "*.json": "${capture}.Development.json",
    "*.cshtml": "${capture}.cshtml.cs,${capture}.cshtml.css",
    "*.razor": "${capture}.razor.cs,${capture}.razor.css",
    "*.resx": "${capture}.Designer.cs",
    "*.xaml": "${capture}.xaml.cs",
    "*.sqlite": "${capture}.${extname}-*",
    "*.db": "${capture}.${extname}-*",
    "*.sqlite3": "${capture}.${extname}-*",
    "*.db3": "${capture}.${extname}-*",
    "*.sdb": "${capture}.${extname}-*",
    "*.s3db": "${capture}.${extname}-*"
  }
}
